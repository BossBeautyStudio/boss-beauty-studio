# ============================================================
# Boss Beauty Studio — Variables d'environnement
# Copie ce fichier en .env.local et remplis chaque valeur
# NE JAMAIS committer .env.local (déjà dans .gitignore)
# ============================================================

# --- Claude / Anthropic ---
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase ---
# https://supabase.com/dashboard/project/<ton-projet>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ⚠️ Serveur uniquement — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Systeme.io Webhooks ---
# Chaîne aléatoire longue — génère avec : openssl rand -base64 32
# ⚠️ Ce nom exact est requis par le code : SYSTEME_WEBHOOK_SECRET
SYSTEME_WEBHOOK_SECRET=change-moi-avec-openssl-rand-base64-32

# --- Vercel Cron (reset quotas mensuels) ---
# Chaîne aléatoire longue — génère avec : openssl rand -base64 32
CRON_SECRET=change-moi-avec-openssl-rand-base64-32

# --- Systeme.io Checkout ---
# URL de la page de paiement Systeme.io (section Tunnels de vente)
NEXT_PUBLIC_SYSTEME_CHECKOUT_URL=https://...systeme.io/...

# --- App ---
# En production : ton domaine Vercel ou domaine custom
# En dev local  : http://localhost:3000
NEXT_PUBLIC_APP_URL=https://ton-domaine.vercel.app

# --- Mode Mock (dev uniquement) ---
# Mettre true pour bypasser Claude et Supabase en local
# NE PAS définir cette variable en production (ou laisser vide / false)
MOCK_GENERATION=false
